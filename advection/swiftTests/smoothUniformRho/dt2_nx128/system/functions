// #includeFunc massTransport(rho, advectingFlux=phiv, scalarFlux=phi,
//                            executeAtStart=yes, diffusivity=none)
// #includeFunc massTransport(T, density=rho, advectingFlux=phi, diffusivity=none,
//                            executeAtStart=no)
#includeFunc multiScalarRKTransport
(
    nFields=2,
    fields=(rho T),
    advectingFlux=phiv,
    massFlux=phi,
    RK_ButcherCoeffs=3 3((1 0 0)
                        (0.25 0.250 0)
                        (0.16667 0.16667 0.66666)),
    gammaCoeffs=(2.5 6.5),
    correctionScheme=cubicUpwind
)

minMax
{
    type coded;
    // Load the library containing the 'coded' functionObject
    libs            ("libutilityFunctionObjects.so" "libfiniteVolumeAtmosFOAM.so");

    codeInclude
    #{
        #include "volFields.H"
    #};

    codeExecute
    #{
        const volScalarField& T
        (
            mesh().lookupObject<volScalarField>("T")
        );

        Info << "T goes from = " << min(T).value() << " to 1 + " 
             << max(T).value()-1 << endl;
    #};
}

