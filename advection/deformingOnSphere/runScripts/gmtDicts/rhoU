FoamFile
{
    version         1.4;
    format          ascii;

    root            "/export/lime/data-04/sws02hs/OpenFOAM/sws02hs-1.4.1/run/shallowWater";
    case            "bucky4_30";
    instance        "constant";
    local           "";

    class           dictionary;
    object          gmtDict;
}

// How to plot
projection "Q180/18c";
//projection "G-90/60/18c";
projection2D latLon;
plotBoundaryDots false;

FieldsToPlot
(
    [rho filledContours 0.575 1.025 0.05 "$GMTU/colours/red_white_blue.cpt"]
    [Co contours 1 50 1 "black"]
    [U  vectors 5.5 13 "black"]
);

// options
region "0/360/-90/90";
boundaryMarks "a60/a60";
separateLegend true;
annotate "minMax 180 -105";
lonMin 360;

