FoamFile
{
    format      ascii;
    class       dictionary;
    location    "system";
    object      fvSolution;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

solvers
{
    "T"
    {
        solver          GAMG; //PBiCGStab; //PBiCG; //smoothSolver;
        //preconditioner  DILU;
        smoother        DILUGaussSeidel; //symGaussSeidel;
        tolerance       1e-6;
        relTol          0;
    }
    TFCT
    {
        $T;
        tolerance       1e-16;
    }
}

PIMPLE
{
    nNonOrthogonalCorrectors 0;
    pRefCell 0;
    pRefValue 0;
}


