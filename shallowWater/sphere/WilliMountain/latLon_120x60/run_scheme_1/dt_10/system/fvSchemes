FoamFile
{   version     2.0;
    format      ascii;
    class       dictionary;
    location    "system";
    object      fvSchemes;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

ddtSchemes
{
    default         Euler;
}

gradSchemes
{
    default         Gauss linear;
}

divSchemes
{
    default         Gauss linearUpwind linearUpwind;
    div(flux)     Gauss linearUpwind linearUpwind;
    div(U,h)     Gauss linearUpwind linearUpwind;
    div(h)     Gauss linearUpwind linearUpwind;

    div(U_S_old,h)   Gauss upwind upwind;
    div(U_S_new,h)   Gauss upwind upwind;
    
}

laplacianSchemes
{
    default         Gauss linear corrected;
}

interpolationSchemes
{
    default         linear;
}

snGradSchemes
{
    default         corrected;
}


