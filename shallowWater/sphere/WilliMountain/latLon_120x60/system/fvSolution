FoamFile
{
    format      ascii;
    class       dictionary;
    location    "system";
    object      fvSolution;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

nIterations 2;
timeOffCentre 0.5;

solvers
{
    "h"
    {
        solver    GAMG;
        smoother  GaussSeidel;
        tolerance 1e-6;
        relTol    0;
    }
}

