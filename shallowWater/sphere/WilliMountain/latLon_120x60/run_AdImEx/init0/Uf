FoamFile
{
    format      ascii;
    class       surfaceVectorField;
    location    "0";
    object      Uf;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 1 -1 0 0];

internalField   uniform (0 0 0);

boundaryField
{
    sides
    {
        type            fixedValue;
        value           uniform (0 0 0);
    }
    originalPatch
    {
        type            fixedValue;
        value           uniform (0 0 0);
    }
    otherSide
    {
        type            fixedValue;
        value           uniform (0 0 0);
    }
}


