FoamFile
{
    format      binary;
    class       volScalarField;
    location    "constant";
    object      h0;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 1 0 0 0 0 0];

internalField   uniform 0;

boundaryField
{
    sides
    {
        type            zeroGradient;
    }
    originalPatch
    {
        type            zeroGradient;
    }
    otherSide
    {
        type            zeroGradient;
    }
}


